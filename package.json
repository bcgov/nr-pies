{
  "name": "nr-pies",
  "version": "0.1.0",
  "license": "(AGPL-3.0-or-later OR CC-BY-4.0)",
  "private": true,
  "description": "NR Permitting Interoperability Exchange Specification",
  "author": "NRM Permitting and Data Solutions <NRM.PermittingAndData@gov.bc.ca>",
  "scripts": {
    "build": "docusaurus build",
    "clear": "docusaurus clear",
    "deploy": "docusaurus deploy",
    "docusaurus": "docusaurus",
    "format": "prettier --write \"**/*.{css,js,json,md,mdx,ts,tsx,yaml}\"",
    "postinstall": "lefthook install",
    "postversion": "npm run version:fix",
    "prebuild": "npm run typecheck",
    "serve": "docusaurus serve",
    "start": "docusaurus start --host 0.0.0.0",
    "swizzle": "docusaurus swizzle",
    "typecheck": "tsc",
    "version": "docusaurus docs:version",
    "version:fix": "node version.helper.mts",
    "write-heading-ids": "docusaurus write-heading-ids",
    "write-translations": "docusaurus write-translations"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@docusaurus/theme-mermaid": "3.10.2",
    "@mdx-js/react": "3.1.1",
    "clsx": "2.1.1",
    "docusaurus-json-schema-plugin": "1.15.1",
    "docusaurus-lunr-search": "3.6.0",
    "mermaid": "11.16.0",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/plugin-rsdoctor": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "lefthook": "2.1.10",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  },
  "allowScripts": {
    "@swc/core@1.15.40": true,
    "core-js@3.49.0": true,
    "fsevents@2.3.3": true,
    "lefthook@2.1.10": true
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.15.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.16.0",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
